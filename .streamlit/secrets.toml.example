# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your values
# NEVER commit secrets.toml to git!

# Password for accessing the dashboard
password = "your-secure-password-here"

# GitHub Gist URL (raw content URL)
# Example: https://gist.githubusercontent.com/username/gist_id/raw/enedis_data.json
gist_url = "https://gist.githubusercontent.com/username/YOUR_GIST_ID/raw/enedis_data.json"
